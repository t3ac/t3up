    }
}           

TCEFORM.tt_content.space_after_class.altLabels.. =  LLL:EXT:t3up/Resources/Private/Language/locallang_backend.xlf:space_class_none


# Designs
TCEFORM {

    tt_content {
        frame_class {
            removeItems = ruler-before, ruler-after, indent, indent-left, indent-right
            disableNoMatchingValueElement = 1
            types {
                slider {
                    addItems { 
                        dynamic       = Dynamic
                     }
                } 
            } // types
        } // frame_class
    } // tt_content  
} // TCEFORM


