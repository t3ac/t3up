lib.header.searchfield = COA
lib.header.searchfield {
    if.isTrue                   = {$page.top.searchfield}
    10 = RECORDS
    10.tables= tt_content
    10.source = {$page.top.searchfield}
    wrap = <li class="d-none d-sm-block topSearchField order-{$page.top.searchbuttonpos}">|</li>
}
[{$page.top.searchpage} in tree.rootLineIds]
    lib.header.searchfield >
    lib.header.searchfield =
    lib.header.searchfield.wrap = <div class="d-none"></div>
[END]
