lib.header.logo.wrap                 	= {$page.header.logowrap}

// German
[siteLanguage("locale") matches "^de_DE^"]
lib.header.logo.10 < lib.header.logo-de
[global]

// English
[siteLanguage("locale") matches "^en_US^"]
lib.header.logo.10 < lib.header.logo-en
[global]

// French
[siteLanguage("locale") matches "^fr_FR^"]
lib.header.logo.10 < lib.header.logo-fr
[global]

// Italian
[siteLanguage("locale") matches "^it_IT^"]
lib.header.logo.10 < lib.header.logo-it
[global]

// Polish
[siteLanguage("locale") matches "^pl_PL^"]
lib.header.logo.10 < lib.header.logo-pl
[global]

// Turkey
[siteLanguage("locale") matches "^tr_TR^"]
lib.header.logo.10 < lib.header.logo-tr
[global]

// Spanish
[siteLanguage("locale") matches "^es_ES^"]
lib.header.logo.10 < lib.header.logo-es
[global]

// Portuguese
[siteLanguage("locale") matches "^pt_PT^"]
lib.header.logo.10 < lib.header.logo-pt
[global]

// Romanian
[siteLanguage("locale") matches "^ro_RO^"]
lib.header.logo.10 < lib.header.logo-ro
[global]

// Chinese
[siteLanguage("locale") matches "^cn_CN^"]
lib.header.logo.10 < lib.header.logo-cn
[global]

##################################################################################

lib.header.logo.100 =< lib.header.logo-de.10
lib.header.logo.100 {
    file                                = {$page.header.mobillogo}
    wrap                                = {$page.header.mobillogowrap} 
}


##################################################################################


lib.header.logoII  = COA
lib.header.logoII.10 = IMAGE
lib.header.logoII.10 {
    file                                = {$page.header.logoII}
    altText                             = Link: {$page.header.alttextII}
    titleText                           = {$page.header.alttextII}
    params                              = type="logo" 
    imageLinkWrap                       = 1
    imageLinkWrap.enable                = 1 
    imageLinkWrap.typolink.parameter    = {$page.header.linklogoII} _blank
    wrap                                = {$page.header.logoIIwrap}
}

