#######################################
#### logo #############################
#######################################

lib.header.logo = COA

lib.header.logo-de = COA
lib.header.logo-de.10 = IMAGE
lib.header.logo-de.10 {
    file                                = {$page.header.logo}
    altText                             = Link: {$page.header.alttext}
    titleText                           = {$page.header.alttext}
    params                              = type="logo" 
    imageLinkWrap                       = 1
    imageLinkWrap.enable                = 1 
    imageLinkWrap.typolink.parameter    = {$page.header.home}    
}

lib.header.logo-en =< lib.header.logo-de
lib.header.logo-en.10.if.isFalse        = {$page.header.logo.en}  
lib.header.logo-en.10.file              = {$page.header.logo}
lib.header.logo-en.20 					= IMAGE
lib.header.logo-en.20 {
    if.isTrue                           = {$page.header.logo.en}
    file                                = {$page.header.logo.en}
    altText                             = Link: {$page.header.alttext}
    titleText                           = {$page.header.alttext}
    params                              = type="logo" 
    imageLinkWrap                       = 1
    imageLinkWrap.enable                = 1 
    imageLinkWrap.typolink.parameter    = {$page.header.home}    
}


