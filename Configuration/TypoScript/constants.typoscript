    preferencesbuttonpos        = 5
        
    # cat= top/functions/11; type= int+; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:quicklinks
    quicklinks          = 
    # cat= top/functions/12; type= type= int[1-10]; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:quicklinksbuttonpos
    quicklinksbuttonpos         = 6

    # cat= top/functions/13; type= options[,1,2,3]; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:languagemenu
    languagemenu            = 

    # cat= top/functions/14; type= int+;label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:loginpage
    loginpage           = 
    # cat= top/functions/15; type = boolean; label = LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:loginbutton
    loginbutton         = 
    # cat= top/functions/16; type= type= int[1-10]; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:loginbuttonpos
    loginbuttonpos          = 7

    # cat= top/searchs/01; type= int+; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:searchpage
    searchpage          = 
    # cat= top/searchs/02; type= boolean; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:searchbutton
    searchbutton            = 
    # cat= top/searchs/03; typetype= int[1-10]; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:searchpos
    searchpos           = 
    # cat= top/searchs/04; type= int+; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:searchfield
    searchfield         = 

    # cat= top/tops/01; type= boolean; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:topposition
    topposition         = active        
    # cat= top/tops/02; type= boolean; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:showtitle
    showtitle           = 
    # cat= top/tops/03; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:topwrap
    topwrap             = w-100 align-items-center justify-content-end 
    # cat= top/tops/04; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:liaclass
    liaclass                = px-3 py-2 px-md-3 py-md-1     
}    

