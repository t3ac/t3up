# customcategory=scss=T3up: Sass    
# customsubcategory=basicSass=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scssbasic 
# customsubcategory=extensions=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scssextensions

page.scss {

    #   Basic _____________________________________________         
    #        
    # cat= scss/basicSass/10; type= options[access,empty]; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scssaccess
    scssaccess          = access 
    # cat= scss/basicSass/11; type= options[links,empty]; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scsslinks
    scsslinks           = links
    # cat= scss/basicSass/12; type= options[fsc,empty]; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scssfsc
    scssfsc             = fsc
    # cat= scss/basicSass/13; type= options[social,empty]; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scsssocialmedia
    scsssocialmedia         = social    

    #   Parts ____________________________________________  
    # cat= scss/basicSass/20; type= options[header,empty]; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scssheader
    scssheader          = header 
    # cat= scss/basicSass/21; type= options[content,empty]; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scsscontent
    scsscontent         = content
    # cat= scss/basicSass/22; type= options[footer ,empty]; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scssfooter
    scssfooter          = footer
    # cat= scss/basicSass/23; type= options[navigation,empty]; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scssnavigation
    scssnavigation          = navigation
    # cat= scss/basicSass/24; type= options[breadcrumb,empty]; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scssbreadcrumb
    scssbreadcrumb          = breadcrumb
    # cat= scss/basicSass/25; type= options[table,empty]; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scsstable
    scsstable           = table 
    # cat= scss/basicSass/26; type= options[bootstrapstyles,empty]; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scssbootstrapstyles
    scssbootstrapstyles     = bootstrapstyles
    # cat= scss/basicSass/27; type= options[subnavigation,empty]; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scsssubnavigation
    scssssubnavigation       = subnavigation
        
    # Extensions ____________________________________________   
    # cat= scss/extensions/101; type= options[lightbox,empty]; label= Lightbox
    scsslightbox            = lightbox
    # cat= scss/extensions/102; type= string]; label= Felogin
    scssfelogin         = EXT:t3up/Resources/Public/Sass/Extensions/_felogin.scss   
    # cat= scss/extensions/103; type= boolean; label= Freewall
    scsswall            = 
 }

# customcategory=totop=T3up: To top

page.totop {
    # cat=totop/01; type=options[empty,totop]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:totopfunction
    totop               = totop 
    # cat=totop/02; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:totopBgColor 
    totopBgColor            = inherit
    # cat=totop/03; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:totopLinkColor
    totopLinkColor          = inherit
    # cat=totop/04; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:totopLinkHoverColor
    totopLinkHoverColor     = inherit
    # cat=totop/05; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:totopPosBottom
    totopPosBottom          = $v1
    # cat=totop/06; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:totopPosRight
    totopPosRight           = $v1
} 
 
# customcategory=typography=T3up: Typography    
# customsubcategory=headers=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:headers 
# customsubcategory=footers=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footers 
# customsubcategory=bread=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bread 

page.typography {
    # cat= typography/bread/01; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:fontsize
    fontsize            = .9rem
    # cat= typography/bread/02; type= int+; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:boldweight
    boldweight          = 600
    # cat= typography/bread/03; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:lineheight
    lineheight          = 
    # cat= typography/bread/04; type= int+; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:linkweight
    linkweight          = 600

    # cat= typography/headers/01; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h1
    h1              = 2.05
    # cat= typography/headers/02; type= int+; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h1.fontweight
    h1.fontweight           = 400
    # cat= typography/headers/03; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h1.lineheight
    h1.lineheight           = 
    # cat= typography/headers/04; type= options[left,center,right]; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h1.direction
    h1.direction            = left
    # cat= typography/headers/05; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h1.margin
    h1.margin           = 0 0 $v025 !important
    # cat= typography/headers/06; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h1.padding
    h1.padding          = 0

    # cat= typography/headers/10; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h2
    h2              = 1.7
    # cat= typography/headers/13; type= int+; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h2.fontweight
    h2.fontweight           = 400
    # cat= typography/headers/14; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h2.margin
    h2.margin           = 0 0 $v050
    # cat= typography/headers/15; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h2.lineheight
    h2.lineheight           = 

    # cat= typography/headers/20; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h3   
    h3              = 1.35
    # cat= typography/headers/21; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h3.md
    h3.fontweight           = 600
    # cat= typography/headers/22; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h3.margin
    h3.margin           = 0 0 $v050
    # cat= typography/headers/23; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h3.lineheight
    h3.lineheight           = 
                
    # cat= typography/headers/30; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h4
    h4              = 1
    # cat= typography/headers/31; type= int+; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h4.fontweight
    h4.fontweight           = 600       
    # cat= typography/headers/32; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h4.margin
    h4.margin           = 0 
    # cat= typography/headers/33; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h4.lineheight
    h4.lineheight           =   
        
    # cat= typography/footers/01; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footer1.fontsize
    footer1.fontsize        = 100%  
    # cat= typography/footers/02; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footer3.fontsize
    footer3.fontsize        = 100%  

    # cat= typography/extra/01; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:navigationfontsize
    navigationfontsize      = 100% 
    # cat= typography/extra/02; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:navigationfontweight
    navFontWeight           = 400
    # cat= typography/extra/03; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:symbolfontsize
    symbolfontsize          = 100%
    # cat= typography/extra/04; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:socialsymbolfontsize
    socialsymbolfontsize    = 175%
}

######################
### Standardvalues###
######################
styles.content.textmedia {
    maxW                = 2560
    maxWInText          = 1200
    linkWrap.width          = 2560m
    linkWrap.height         = 1200m
    linkWrap.lightboxEnabled    = 1
}
