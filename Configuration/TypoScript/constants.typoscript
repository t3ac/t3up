	 header{	
		#	customsubcategory=logo=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:logos	
		# cat =t3up: header/logo/001; type=string; label	=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:logo 
		logo						= typo3conf/ext/t3up/Resources/Public/Design/Logo.svg 
		# cat =t3up: header/logo/002; type =string; label	=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:logo.1 
		logo.en						=
		# cat =t3up: header/logo/003; type =string; label	=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:logo.2 
		logo.fr						=
		# cat =t3up: header/logo/004; type =string; label	=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:logo.3
		logo.it						=
		# cat =t3up: header/logo/005; type =string; label	=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:logo.4 
		logo.pl						=
		# cat =t3up: header/logo/006; type =string; label	=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:logo.5
		logo.tr						=
		# cat =t3up: header/logo/007; type =string; label	=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:logo.6
		logo.es						=
		# cat =t3up: header/logo/008; type =string; label	=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:logo.7
		logo.pt						=
		# cat =t3up: header/logo/009; type =string; label	=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:logo.8
		logo.ro						=
		# cat =t3up: header/logo/010; type =sing; label	=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:logo.9
		logo.cn						=
				
		# cat=t3up: header/logo/101; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:alttext	
		alttext						= Home	
		# cat=t3up: header/logo/102; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:logowidth
		logowidth					= 100%	 
		# cat=t3up: header/logo/103; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:logowrap
		logowrap					=<div class="logo d-none d-md-inline-block col-3 my-auto p-3">|</div> 		
		
		# cat=t3up: header/logo/104; type=options[1,2,3,4,5]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:logopos
		logopos						= 1
		# cat=t3up: header/logo/105; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:notlogowrap
		notlogowrap					= d-flex col-9 flex-wrap vertical-align-stretch 		
		# cat=t3up: header/logo/106; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:logostickywidth
		logostickywidth					= 33.33%	 


		# cat=t3up: header/logo/200; type=string; label	=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:logoII 
		logoII						=
		# cat=t3up: header/logo/201; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:alttextII	
		alttextII					= Partner	
		# cat=t3up: header/logo/202; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:linklogoII 
		linklogoII					= https://typo3.org
		# cat=t3up: header/logo/203; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:logoIImaxwidth
		logoIIwidth					= 30%
		# cat=t3up: header/logo/204; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:logoIIwrap
		logoIIwrap					= <div class="logoII d-inline-block ms-auto my-auto p-3">|</div>			 

		# cat=t3up: header/logo/300; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:mobillogo
		mobillogo					=
		# cat=t3up: header/logo/301; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:mobillogowrap
		mobillogowrap					= <div class="col-3 d-md-none weblogo p-3">|</div>
		# cat=t3up: header/logo/302; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:mobillogowidth
		mobillogowidth					= 100%
				
		# cat=t3up: header//01; type=int+;	label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:home
		home						= 1		
		# cat=t3up: header//02; type=options[,header]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:dynheader
		dynheader					=		

		# cat=t3up: header//03; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:headcontainer	
		headcontainer					= container	

	 }		
	
	 meta {
		# cat=t3up: meta//; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:meta.author
		author						=
		# cat=t3up: meta//; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:meta.compatible
		compatible					=IE	=edge	
		# cat=t3up: meta//; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:meta.copyright
		copyright					=T3AC
		# cat=t3up: meta//; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:meta.description
		description					=
		# cat=t3up: meta//; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:meta.google
		google						=notranslate
		# cat=t3up: meta//; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:meta.google-site-verification
		google-site-verification	=
		# cat=t3up: meta//; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:meta.keywords
		keywords					=
		# cat=t3up: meta//; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:meta.language
		language					= de	
		# cat=t3up: meta//; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:meta.publisher
		publisher					=
		# cat=t3up: meta//; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:meta.page-topic
		page-topic					=
		# cat=t3up: meta//; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:meta.robots
		robots						=index, follow
		# cat=t3up: meta//; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:meta.viewport
		viewport					=width	=device-width, initial-scale	=1.0
		# cat=t3up: meta//; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:meta.og-image
		og-image					=
		# cat=t3up: meta//; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:meta.og-title
		og-title					=
		# cat=t3up: meta//; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:meta.og-description
		og-description				=
		# cat=t3up: meta//; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:meta.og-type
		og-type						=
		# cat=t3up: meta//; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:meta.og-url
		og-url						=
		# cat=t3up: meta//; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:meta.og-site_name
		og-site_name				=
	 } 
	 
	 navigation {
