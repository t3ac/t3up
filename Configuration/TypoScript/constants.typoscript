		# cat=t3up: top/functions/11; type=int+; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:quicklinks
		quicklinks					=
		# cat=t3up: top/functions/12; type=type=int[1-10]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:quicklinksbuttonpos
		quicklinksbuttonpos 		= 6
	
		# cat=t3up: top/functions/13; type=options[,1,2,3]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:languagemenu
		languagemenu				=
	
		# cat=t3up: top/functions/14; type=int+; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:loginpage
		loginpage					=
        	# cat=t3up: top/functions/15; type =options[,active]; label =LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:loginbutton
        	loginbutton                   =
		# cat=t3up: top/functions/16; type=type=int[1-10]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:loginbuttonpos
	    	loginbuttonpos				= 7
	
		# customsubcategory=searchs=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:searchs	
		# cat=t3up: top/searchs/01; type=int+; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:searchpage
		searchpage					=	 
		# cat=t3up: top/searchs/02; type=options[,active]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:searchbutton
		searchbutton				=	 
		# cat=t3up: top/searchs/03; typetype=int[1-10]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:searchpos	
		searchpos					= 9 
		# cat=t3up: top/searchs/04; type=int+; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:searchfield
		searchfield					=
		
		#	customsubcategory=tops=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:tops 
		# cat=t3up: top/tops/01; type=options[,active]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:topposition
		topposition					= active		
		# cat=t3up: top/tops/02; type=options[0,1]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:showtitle
		showtitle					=	
		# cat=t3up: top/tops/03; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:topwrap
		topwrap						= w-100 align-items-center justify-content-end 
	 }	 
	 
	 totop {
	 	# customsubcategory=totop=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:totop
		# cat=t3up: totop/totop/01; type=options[empty,totop]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:totopfunction
		totop						= totop 
		# cat=t3up: totop/totop/02; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:totopBgColor 
		totopBgColor				=inherit
		# cat=t3up: totop/totop/03; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:totopLinkColor
		totopLinkColor				=inherit
		# cat=t3up: totop/totop/04; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:totopLinkHoverColor
		totopLinkHoverColor			=inherit
		# cat=t3up: totop/totop/05; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:totopPosBottom
		totopPosBottom				= 1rem
		# cat=t3up: totop/totop/06; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:totopPosRight
		totopPosRight				= 1rem
	} 
	 
	
	 typography {
		# customsubcategory=bread=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bread	
		# cat=t3up: typography/bread/01; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:fontsize
		fontsize						= clamp(.9rem, 1rem, 1.2rem)
		# cat=t3up: typography/bread/02; type=int+; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:boldweight
		boldweight						= 600
		# cat=t3up: typography/bread/03; type= string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:lineheight
		lineheight						= 
		# cat=t3up: typography/bread/04; type=int+; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:linkweight
		linkweight						= 600
		
		# customsubcategory=headers=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:headers	
		# cat=t3up: typography/headers/01; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h1
		h1								= 2.05
		# cat=t3up: typography/headers/02; type=int+; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h1.fontweight
	 	h1.fontweight					= 400
		# cat=t3up: typography/headers/03; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h1.lineheight
		h1.lineheight					= 
		# cat=t3up: typography/headers/04; type=options[left,center,right]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h1.direction
		h1.direction					=left
		# cat=t3up: typography/headers/05; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h1.margin
		h1.margin						= 0 0 $v4 !important
		# cat=t3up: typography/headers/06; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h1.padding
	 	h1.padding						= 0
	
		# cat=t3up: typography/headers/10; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h2
		h2								= 1.7
		# cat=t3up: typography/headers/13; type=int+; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h2.fontweight
		h2.fontweight					=400
		# cat=t3up: typography/headers/14; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h2.margin
	 	h2.margin						= 0 0 $v2
		# cat=t3up: typography/headers/15; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h2.lineheight
		h2.lineheight					= 

		# cat=t3up: typography/headers/20; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h3	
		h3								= 1.35
		# cat=t3up: typography/headers/21; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h3.md
		h3.fontweight					= 600
		# cat=t3up: typography/headers/22; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h3.margin
		h3.margin						= 0 0 $v2
		# cat=t3up: typography/headers/23; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h3.lineheight
		h3.lineheight					= 
					
		# cat=t3up: typography/headers/30; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h4
		h4								= 1
		# cat=t3up: typography/headers/31; type=int+; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h4.fontweight
		h4.fontweight					= 600		
		# cat=t3up: typography/headers/32; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h4.margin
		h4.margin						= 0 
		# cat=t3up: typography/headers/33; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h4.lineheight
		h4.lineheight					= 	
			
		# customsubcategory=footers=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footers	
		# cat=t3up: typography/footers/01; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footer1.fontsize
		footer1.fontsize				= 100%	
		# cat=t3up: typography/footers/02; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footer3.fontsize
		footer3.fontsize				= 100%	

		# cat=t3up: typography/extra/01; type= string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:navigationfontsize
		navigationfontsize				= 100% 
		# cat=t3up: typography/extra/02; type= string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:navigationfontweight
		navFontWeight					= 400
		# cat=t3up: typography/extra/03; type= string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:symbolfontsize
		symbolfontsize					= 100%

	 }
}


######################
###	Standardvalues###
######################
styles.content.textmedia {
	 maxW						= 2560
	 maxWInText					= 1200
	 linkWrap.width				= 2560m
	 linkWrap.height			= 1200m
	 linkWrap.lightboxEnabled	= 1
}

