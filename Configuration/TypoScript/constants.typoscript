	 config {
		# cat=t3up: config/appearance/; type=string; label=Header Comment
		headerComment				=	TYPO3 Package by Michael Lang - https://h-da.de
		# cat=t3up: config/admin/01; type=boolean; label=No Cache (for Development)
		no_cache				=	0
		# cat=t3up: config/admin/02; type=options[Do not remove	=0,Remove	=1,Move to external file	=external]; label=Remove default JavaScript
		removeDefaultJS				=	0
		# cat=t3up: config/admin/03; type=boolean; label=Admin Panel
		admPanel				=	1
		# cat=t3up: config/admin/04; type=boolean; label=Show errors, 0=Old version, 1=Show: occured ...
		ExceptionHandler			=	1
		# cat=t3up: config/admin/05; type=boolean; label=Index on/off
		index_enable				=	1
		# cat=t3up: config/admin/06; type=boolean; label=External index on/off
		index_externals				=	1
		# cat=t3up: config/admin/08; type=boolean;	label=Debug activation
		debug					=	0
		# cat=t3up: config/admin/07; type=string; label= Separator of the website-title
		pageTitleSeparator			= 	| 

		#	customsubcategory=compressfiles=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:compressfiles
		# cat=t3up: config/compressfiles/01; type=boolean; label=Compress JavaScript
		compressJs				=	0
		# cat=t3up: config/compressfiles/02; type=boolean; label=Compress Css
		compressCss				=	0
		# cat=t3up: config/compressfiles/03; type=boolean; label=Concatenate JavaScript
		concatenateJs				=	0
		# cat=t3up: config/compressfiles/04; type=boolean; label=Concatenate Css
		concatenateCss				=	0 
	 }
	 
	 design {
		# cat=t3up: fluid_style_content//; type=string; label=Imageborder
		borderWidth				=	0
		# cat=t3up: fluid_style_content//; type=string; label=Border spacing
		borderPadding				=	0
		# cat=t3up: fluid_style_content//; type=string; label=Bordercolor
		borderColor				=	#000
		# cat=t3up: fluid_style_content//; type=string; label=Text-margin
		textMargin				=	0
		# cat=t3up: fluid_style_content//; type=string; label=Distance between columns
		columnSpacing				=	0
		# cat=t3up: fluid_style_content//; type=string; label=Distance between rows
		rowSpacing				=	0
		# cat=t3up: fluid_style_content//; type=string; label=Standard distance
		base					=	100%
	 }	
	 
	 files{
		# cat=t3up: files//100; type=string; label=Favicon
		favicon					=	EXT:t3up/Resources/Public/Design/favicon.ico
			
		# customsubcategory=contentElement	=	LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:contentElement
		# cat=t3up: files/contentElement/01;	type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:contentElement.layoutpath
		contentElement.layoutRootPaths		=	EXT:t3up/Resources/Private/Templates/ContentElement/Layouts/
		# cat=t3up: files/contentElement/02;	type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:contentElement.partialpath
		contentElement.partialRootPaths		=	EXT:t3up/Resources/Private/Templates/ContentElement/Partials/
		# cat=t3up: files/contentElement/03;	type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:contentElement.templatepath
		contentElement.templateRootPaths	=	EXT:t3up/Resources/Private/Templates/ContentElement/Templates/
			
		# customsubcategory=fluidtemplates	=	LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:fluidtemplates
		# cat=t3up: files/fluidtemplates/01;	type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:fluidtemplates.layoutpath
		fluidtemplates.layoutRootPaths		=	EXT:t3up/Resources/Private/Templates/Fluidtemplates/Layouts/
		# cat=t3up: files/fluidtemplates/02;	type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:fluidtemplates.partialpath
		fluidtemplates.partialRootPaths		=	EXT:t3up/Resources/Private/Templates/Fluidtemplates/Partials/
		# cat=t3up: files/fluidtemplates/03;	type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:fluidtemplates.templatepath
		fluidtemplates.templateRootPaths	=	EXT:t3up/Resources/Private/Templates/Fluidtemplates/Templates/		
				 
		# customsubcategory=javascript		=	LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:javascript
		# cat=t3up: files/javascript/01; type=options[,active]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:basic 
		basic					=	active
		# cat=t3up: files/javascript/02; type=options[,active]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:subnavigation
		subnavigation				=
		# cat=t3up: files/javascript/04; type=options[,active]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:jquery
		jquery					=	active
		# cat=t3up: files/javascript/04; type=options[,active]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:inview	
		inview 					= 	active
		# cat=t3up: files/javascript/05; type=options[,active]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:wall		
		wall 					= 	active
	 }	
	
	 fonts{	 
		# cat=t3up: fonts//01;	type=options[Arial,Open Sans,PT Sans,Roboto,Source Sans Pro,Ubuntu,Verdana,Ropa Sans]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:font
		font					=Arial
		# cat=t3up: fonts//02;	type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:fontdef
		fontdef					=../vendor/t3ac/t3up/Resources/Public/Sass/
		# cat=t3up: fonts//03;	type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:fontpath
		fontpath				=../vendor/t3ac/t3up/Resources/Public/Fonts/	
		# cat=t3up: fonts//04;	type=options[Courier,Times]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:font2
		font2					=Courier
		# cat=t3up: fonts//05;	type=options[empty,'FontAwesome']; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:symbol	 
		symbol					='FontAwesome'
		symbolfiles				= FontAwesome	
		# cat=t3up: fonts//06;	type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:symbolfontdef
		symbolfontdef				=../vendor/t3ac/t3up/Resources/Public/Sass/
		# cat=t3up: fonts//07;	type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:symbolfontpath
		symbolfontpath				=../vendor/t3ac/t3up/Resources/Public/Fonts/			
	 }	

	 footer{ 
		#	customsubcategory=bg1=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bg1	
