		# cat=t3up: color/headercolor/02; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h2-color
		h2-color				=inherit	
		# cat=t3up: color/headercolor/03; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h3-color
		h3-color				=inherit
		# cat=t3up: color/headercolor/04; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h4-color
		h4-color				=inherit
			
		#	customsubcategory=pagecolor=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:pagecolor
		# cat=t3up: color/pagecolor/01; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:blue
		blue						=#346097
		# cat=t3up: color/pagecolor/02; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:green
		green						=#406C03
		# cat=t3up: color/pagecolor/03; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:grey
		grey						=#787878
		# cat=t3up: color/pagecolor/04; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:orange
		orange						=#A94611
		# cat=t3up: color/pagecolor/05; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:red
		red						=#A50F19
		# cat=t3up: color/pagecolor/06; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:turquoise
		turquoise					=#1D725F
		# cat=t3up: color/pagecolor/07; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:violett
		violett						=#863177
		# cat=t3up: color/pagecolor/08; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:yellow
		yellow						=#F5F507
		# cat=t3up: color/pagecolor/09; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:darkblue
		darkblue					=#2D4F9A
		# cat=t3up: color/pagecolor/10; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:darkgrey
		darkgrey					=#454545
			
		#	customsubcategory=footer=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footer
		# cat=t3up: color/footer/01; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footer1BGColor 
		footer1BgColor				=inherit
		# cat=t3up: color/footer/02; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footer1TextColor
		footer1TextColor			=inherit
		# cat=t3up: color/footer/03; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footer1LinkColor
		footer1LinkColor			=inherit
		# cat=t3up: color/footer/04; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footer1LinkHoverColor
		footer1LinkHoverColor			=inherit
		# cat=t3up: color/footer/06; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footer2BGColor 
		footer2BgColor				=inherit			
		# cat=t3up: color/footer/06; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footer3BGColor 
		footer3BgColor				=inherit	
		# cat=t3up: color/footer/07; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footer3TextColor
		footer3TextColor			=inherit
		# cat=t3up: color/footer/08; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footer3LinkColor
		footer3LinkColor			=inherit
		# cat=t3up: color/footer/09; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footer3LinkHoverColor
		footer3LinkHoverColor			=inherit
			
		#	customsubcategory=bootstrap=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bootstrap
		# cat=t3up: color/bootstrap/01; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bootstrapcolor.danger
		danger						=#dc3545
		# cat=t3up: color/bootstrap/02; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bootstrapcolor.warning
		warning						=#ffc107
		# cat=t3up: color/bootstrap/03; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bootstrapcolor.success
		success						=#28a745
		# cat=t3up: color/bootstrap/04; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bootstrapcolor.primary
		primary						=#007bff
		# cat=t3up: color/bootstrap/05; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bootstrapcolor.secondary
