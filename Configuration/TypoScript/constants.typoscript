		# cat=t3up: navigation//113; type=options[0,1]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:sideAnker
		sideAnker					= 0	
		# cat=t3up: navigation//114; type=options[leftround,leftsquare,rightround,rightsquare]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:sideAnkerstyle
		sideankerstylefunction		= leftround	
		# cat=t3up: navigation//115;  type=int+; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:burgerAnkerExtra
		burgerAnkerExtra			= 	
			
	 }
			
	 scss {

		#	Basic _____________________________________________			
		#	customsubcategory=basic=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scssbasic 
		#		 
		# cat=t3up: scss/basic/10;	type=options[access,empty]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scssaccess
		scssaccess					=access 
		# cat=t3up: scss/basic/11;	type=options[links,empty]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scsslinks
		scsslinks					=links
		# cat=t3up: scss/basic/12;	type=options[fsc,empty]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scssfsc
		scssfsc						=fsc
		# cat=t3up: scss/basic/13;	type=options[social,empty]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scsssocialmedia
		scsssocialmedia				=social	

		#	Parts ____________________________________________	
		# cat=t3up: scss/basic/20;	type=options[header,empty]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scssheader
		scssheader					= header 
		# cat=t3up: scss/basic/21;	type=options[content,empty]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scsscontent
		scsscontent					= content
		# cat=t3up: scss/basic/22;	type=options[footer ,empty]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scssfooter
		scssfooter					= footer
		# cat=t3up: scss/basic/23;	type=options[navigation,empty]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scssnavigation
		scssnavigation				= navigation
		# cat=t3up: scss/basic/24;	type=options[breadcrumb,empty]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scssbreadcrumb
		scssbreadcrumb				= breadcrumb
		# cat=t3up: scss/basic/25; type= options[subnavigation,empty]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scsssubnavigation
		scsssubnavigation			= empty
		# cat=t3up: scss/basic/27; type= options[table,empty]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scsstable
		scsstable					= table	
		# cat=t3up: scss/basic/28; type= options[bootstrapstyles,empty]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scssbootstrapstyles
		scssbootstrapstyles			= bootstrapstyles
			
		# Extensions ____________________________________________	
		# customsubcategory=extensions=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:scssextensions
		# cat=t3up: scss/extensions/101;	type=options[lightbox,empty]; label= Lightbox
		scsslightbox					= lightbox
		# cat=t3up: scss/extensions/102;	type=string]; label= Felogin
		scssfelogin					= EXT:t3up/Resources/Public/Sass/Extensions/_felogin.scss	
		# cat=t3up: scss/extensions/103;	type=options[wall,empty]; label= Freewall
		scsswall					= wall	
	 }
	 
