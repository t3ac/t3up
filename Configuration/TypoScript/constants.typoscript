    footerBaseWrap          = <div class= "footer3"><div class= "container"><div class= "row justify-content-between px-3 py-3 pe-7 px-xxl-0">|</div></div></div>
}

#   customcategory=headerarea=T3up: Header  
#   customsubcategory=logo=Logo 

page.header{
    # cat = headerarea/logo/001; type= string; label    = LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:logo 
    logo                = 
            
    # cat= headerarea/logo/101; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:alttext    
    alttext             = Home  
    # cat= headerarea/logo/102; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:logowidth
    logowidth           = 100%   
    # cat= headerarea/logo/103; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:logowrap
    logowrap            = <div class= "logo d-none d-md-inline-block col-3 px-3">|</div>        
    
    # cat= headerarea/logo/105; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:notlogowrap
    notlogowrap         = d-flex col-9 flex-wrap vertical-align-stretch         
    # cat= headerarea/logo/106; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:logostickywidth
    logostickywidth         = 33.33%     

    # cat= headerarea/logo/300; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:mobillogo
    mobillogo           = 
    # cat= headerarea/logo/301; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:mobillogowrap
    mobillogowrap           = <div class= "col-3 d-md-none weblogo p-3">|</div>
    # cat= headerarea/logo/302; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:mobillogowidth
    mobillogowidth          = 100%
            
    # cat= headerarea/01; type= int+; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:home
    home                = 1     
    # cat= headerarea/02; type= options[no-dyn,shy-header,sticky-header,fixed]; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:dynheader
    dynheader           = no-dyn

    # cat= headerarea/03; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:headcontainer    
    headcontainer           = container d-flex

    # cat= headerarea/04; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:area 
    area                = d-flex
}

# customcategory=top=T3up: Top-Header   
# customsubcategory=functions=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:functions
# customsubcategory=searchs=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:searchs
