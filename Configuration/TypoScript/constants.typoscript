##############
###    PAGE###
##############

styles.content.loginform.recursive      = 4
styles.content.loginform.redirectFirstMethod    = 1
styles.content.loginform.redirectDisable    = 0
styles.content.loginform.redirectMode       = login,logout,getpost,userLogin,referer,refererDomains,loginError



# customcategory=breadcrumbs=T3up: Breadcrumb

page {
    breadcrumb{
        # cat= breadcrumbs/01; type= options[0,1,2]; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:breadcrumbstyle
        breadcrumbstyle         = 1 
        # cat= breadcrumbs/02; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:breadcrumbwrap
        breadcrumbwrap          = breadcrumbrow navbar navbar-expand-lg d-none d-lg-flex p-3
        # cat= breadcrumbs/03; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:breadcrumbulwrap
        breadcrumbulwrap        = align-items-center list-unstyled navbar-nav me-auto   
        # cat= breadcrumbs/04; type= options[d-none,d-block];label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:breadcrumbstart
        breadcrumbstart         = d-block
        # cat= breadcrumbs/05; type= boolean; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:breadcrumbtext
        breadcrumbtext          = 1
        # cat= breadcrumbs/05; type= string;label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:breadcrumbtextsize
        breadcrumbtextsize      = 80%
        # cat= breadcrumbs/06; type= boolean;label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:breadcrumbtop
        breadcrumbtop          = 
    }
}

# customcategory=components=T3up: Components

page {
    components{
        # cat= components/01; type= int+; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:container
        container           = 1440
        # cat= components/02; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:gutter
        gutter              = clamp(12px, 2.8vw, 24px)
        # cat= components/04; type= options[empty,access]; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:access
        access              = access
        # cat= components/05; type= options[empty,meanmenu,mmenu,simplemenu]; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:mobil
        mobilmenu           = mmenu                 
        # cat= components/06; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:mainpadding
        mainpadding         = 0 0 $v6 0
    }
}

# customcategory=colors=T3up: Colors
# customsubcategory=base=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:basecolors
# customsubcategory=header=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:header
# customsubcategory=navigationcolor=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:navigationcolor
# customsubcategory=headercolor=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:headercolor
# customsubcategory=pagecolors=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:pagecolors
# customsubcategory=footerColors=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footerColors
# customsubcategory=bootstrap= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bootstrap

page.color {
    # cat= colors/base/01; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:baseColor
    baseColor           = #151515
    # cat= colors/base/02; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:baseTextColor
    textColor           = #151515
    # cat= colors/base/03; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:baseLinkColor
    linkColor           = #151515
    # cat= colors/base/04; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:baseLinkHoverColor
    linkHoverColor          = $black
    # cat= colors/base/05; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bodyBgColor
    bodyBgColor         = transparent
    # cat= colors/base/06; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:baseContainerBgColor
    baseContainerBgColor        = transparent
    # cat= colors/base/07; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:shadow
    shadow              = 0 $v025 $v050 0 rgba(0,0,0,.2)

    # cat= colors/header/01; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:headerBgColor
    headerBgColor           = inherit
    # cat= colors/header/02; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:headerColor
    headerColor         = #666
    # cat= colors/header/03; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:headerLinkColor
    headerLinkColor         = #666
    # cat= colors/header/04; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:headerLinkHoverColor
    headerLinkHoverColor        = #333
    # cat= colors/header/05; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:topBgColor
    topBgColor          = #ccc
    # cat= colors/header/06; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:topBgColorTrans
    topBgColorTrans         = 1
    # cat= colors/header/07; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:topLinkColor
    topLinkColor            = #666
    # cat= colors/header/08; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:topLinkHoverColor
    topLinkHoverColor       = inherit
    # cat= colors/header/09; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:breadcrumbtopcolor
    breadcrumbtop           = inherit
    
    
    # cat= colors/navigationcolor/020; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:navLinkColor
    navLinkColor            = #333   
    # cat= colors/navigationcolor/021; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:navLinkHoverColor
    navLinkHoverColor       = #000   
    # cat= colors/navigationcolor/022; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:subnavLinkColor
    subnavLinkColor         = #333   
    # cat= colors/navigationcolor/023; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:subnavLinkHoverColor
    subnavLinkHoverColor        = #000  
    # cat= colors/navigationcolor/024; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:subNavBG
    subNavBG            = rgba(255, 255, 255, .98)  
    # cat= colors/navigationcolor/025 type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:navLinkHoverBGColor
    navLinkHoverBGColor     = rgba(255, 255, 255, 0)    
    # cat= colors/navigationcolor/026; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:navBorderBottomColor
    navBorderBottomColor        = rgba(100, 100, 100, 1)    
    # cat= colors/navigationcolor/027; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:overlay
    overlay             = rgba(33, 33, 33, 0.35)             
    # cat= colors/navigationcolor/028; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:sideankercolorBg
    sideankercolorBg        = $white
    # cat= colors/navigationcolor/029; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:sideankerlicolor
    sideankerlicolor        = #333333
    
    # cat= colors/footerColors/01; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footer1BGColor 
    footer1BgColor          = inherit
    # cat= colors/footerColors/02; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footer1TextColor
    footer1TextColor        = inherit
    # cat= colors/footerColors/03; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footer1LinkColor
    footer1LinkColor        = inherit
    # cat= colors/footerColors/04; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footer1LinkHoverColor
    footer1LinkHoverColor       = inherit
    # cat= colors/footerColors/05; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footer2BGColor 
    footer2BgColor          = inherit           
    # cat= colors/footerColors/06; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footer3BGColor 
    footer3BgColor          = inherit   
    # cat= colors/footerColors/07; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footer3TextColor
    footer3TextColor        = inherit
    # cat= colors/footerColors/08; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footer3LinkColor
    footer3LinkColor        = inherit
    # cat= colors/footerColors/09; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footer3LinkHoverColor
    footer3LinkHoverColor       = inherit

    # cat= colors/headercolor/01; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h1-color
    h1-color            = inherit
    # cat= colors/headercolor/02; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h2-color
    h2-color            = inherit   
    # cat= colors/headercolor/03; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h3-color
    h3-color            = inherit
    # cat= colors/headercolor/04; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h4-color
    h4-color            = inherit
    
    # cat= colors/pagecolors/00; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:blue
    blue                = #346097
    # cat= colors/pagecolors/01; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:green
    green               = #406C03
    # cat= colors/pagecolors/02; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:grey
    grey                = #787878
    # cat= colors/pagecolors/03; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:orange
    orange              = #A94611
    # cat= colors/pagecolors/04; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:red
    red             = #A50F19
    # cat= colors/pagecolors/05; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:turquoise
    turquoise           = #1D725F
    # cat= colors/pagecolors/06; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:violett
    violett             = #863177
    # cat= colors/pagecolors/07; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:yellow
    yellow              = #F5F507
    # cat= colors/pagecolors/08; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:darkblue
    darkblue            = #2D4F9A
    # cat= colors/pagecolors/09; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:darkgrey
    darkgrey            = #454545
    # cat= colors/pagecolors/10; type = color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:lightgrey
    lightgrey           = #dadada

    # cat= colors/bootstrap/081; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bootstrapcolor.danger
    danger              = #dc3545
    # cat= colors/bootstrap/082; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bootstrapcolor.warning
    warning             = #ffc107
    # cat= colors/bootstrap/083; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bootstrapcolor.success
    success             = #28a745
    # cat= colors/bootstrap/084; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bootstrapcolor.primary
    primary             = #007bff
    # cat= colors/bootstrap/085; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bootstrapcolor.secondary
    secondary           = #6c757d
    # cat= colors/bootstrap/086; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bootstrapcolor.info
    info                = #17A2B8
    # cat= colors/bootstrap/088; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bootstrapcolor.light
    light               = #f8f9fa
    # cat= colors/bootstrap/089; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bootstrapcolor.dark
    dark                = #343a40
    # cat= colors/bootstrap/080; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bootstrapcolor.link
    link                = #0056b3
    # cat= colors/bootstrap/090; type= options[,'+','\f107','\f078','\f13a','\f0ab','\f063']; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bootstrapcolor.plus
    plus                = '+'
    # cat= colors/bootstrap/091; type= options[,'–','\f107','\f078','\f13a','\f0ab','\f063']; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bootstrapcolor.minus
    minus               = '–'
}

# customcategory=config=T3up: Config
# customsubcategory=configa=Compress
# customsubcategory=admin=Config

page.config {
    # cat= config/appearance/; type= string; label= Header Comment
    headerComment           = TYPO3 Package by Michael Lang - https:/h-da.de
    # cat= config/admin/01; type= boolean; label= No Cache (for Development)
    no_cache            = 0
    # cat= config/admin/02; type= options[Do not remove = 0,Remove = 1,Move to external file    = external]; label= Remove default JavaScript
    removeDefaultJS         = 0
    # cat= config/admin/03; type= boolean; label= Admin Panel
    admPanel            = 1
    # cat= config/admin/04; type= boolean; label= Show errors, 0 = Old version, 1= Show: occured ...
    ExceptionHandler        = 1
    # cat= config/admin/05; type= boolean; label= Index on/off
    index_enable            = 1
    # cat= config/admin/06; type= boolean; label= External index on/off
    index_externals         = 1
    # cat= config/admin/08; type= boolean; label= Debug activation
    debug               = 0
    # cat= config/admin/07; type= string; label= Separator of the website-title
    pageTitleSeparator      = | 

    # customsubcategory= compressfiles= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:compressfiles
    # cat= config/configa/01; type= boolean; label= Compress JavaScript
    compressJs          = 0
    # cat= config/configa/02; type= boolean; label= Compress Css
    compressCss         = 0
    # cat= config/configa/03; type= boolean; label= Concatenate JavaScript
    concatenateJs           = 0
    # cat= config/configa/04; type= boolean; label= Concatenate Css
    concatenateCss          = 0 
}

# customcategory=design=T3up: Fluid style content

page.design {
    # cat= design/fluid_style_content/; type= string; label= Imageborder
    borderWidth         = 0
    # cat= design/fluid_style_content/; type= string; label= Border spacing
    borderPadding           = 0
    # cat= design/fluid_style_content/; type= string; label= Bordercolor
    borderColor         = #000
    # cat= design/fluid_style_content/; type= string; label= Text-margin
    textMargin          = 0
    # cat= design/fluid_style_content/; type= string; label= Distance between columns
    columnSpacing           = 0
    # cat= design/fluid_style_content/; type= string; label= Distance between rows
    rowSpacing          = 0
    # cat= design/fluid_style_content/; type= string; label= Standard distance
    base                = 100%
 }  

# customcategory=files=T3up: Files
# customsubcategory=contentElement=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:contentElement
# customsubcategory=fluidtemplates=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:fluidtemplates
# customsubcategory=javascript=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:javascript

page.files{
    # cat= files/100; type= string; label= Favicon
    favicon             = EXT:t3up/Resources/Public/Design/favicon.ico
        
    # cat= files/contentElement/01; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:contentElement.layoutpath
    contentElement.layoutRootPaths = EXT:t3up/Resources/Private/Templates/ContentElement/Layouts/
    # cat= files/contentElement/02; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:contentElement.partialpath
    contentElement.partialRootPaths = EXT:t3up/Resources/Private/Templates/ContentElement/Partials/
    # cat= files/contentElement/03; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:contentElement.templatepath
    contentElement.templateRootPaths    = EXT:t3up/Resources/Private/Templates/ContentElement/Templates/
        
    # cat= files/fluidtemplates/01; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:fluidtemplates.layoutpath
    fluidtemplates.layoutRootPaths = EXT:t3up/Resources/Private/Templates/Fluidtemplates/Layouts/
    # cat= files/fluidtemplates/02; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:fluidtemplates.partialpath
    fluidtemplates.partialRootPaths = EXT:t3up/Resources/Private/Templates/Fluidtemplates/Partials/
    # cat= files/fluidtemplates/03; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:fluidtemplates.templatepath
    fluidtemplates.templateRootPaths    = EXT:t3up/Resources/Private/Templates/Fluidtemplates/Templates/        
             
    # cat= files/javascript/01; type= boolean; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:basic 
    basic               = active
    # cat= files/javascript/02; type= boolean; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:jquery
    jquery              = active
    # cat= files/javascript/03; type= boolean; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:subnavigation
    subnavigation       = 
    # cat= files/javascript/04; type= boolean; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:inview    
    inview              = 
    # cat= files/javascript/05; type= boolean; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:wall      
    wall                = 
}

# customcategory=fonts=T3up: Fonts

page.fonts{  
    # cat= fonts/01; type= options[Arial,Open Sans,PT Sans,Roboto,Source Sans Pro,Ubuntu,Verdana,Ropa Sans]; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:font
    font                = Arial
    # cat= fonts/02; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:fontdef
    fontdef             = ../vendor/t3ac/t3up/Resources/Public/Sass/
    # cat= fonts/03; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:fontpath
    fontpath            = ../vendor/t3ac/t3up/Resources/Public/Fonts/
    
    # cat= fonts/04; type= options[Courier,Times]; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:font2
    font2               = Courier   
    # cat= fonts/05; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:fontdef2
    fontdef2            = ../vendor/t3ac/t3up/Resources/Public/Sass/
    # cat= fonts/06; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:fontpath2
    fontpath2           = ../vendor/t3ac/t3up/Resources/Public/Fonts/   

    # cat= fonts/07; type= options[empty,'FontAwesome']; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:symbol   
    symbolfont              = 'FontAwesome'
    # cat= fonts/08; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:symbolfontdef
    symbolfontdef           = ../vendor/t3ac/t3up/Resources/Public/Sass/
    # cat= fonts/09; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:symbolfontpath
    symbolfontpath          = ../vendor/t3ac/t3up/Resources/Public/Fonts/           
 }  

# customcategory=footer=T3up: Footer
# customsubcategory=bg1= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bg1    
# customsubcategory=bg2= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bg2    

page.footer{ 
    # cat= footer/bg1/00; type= boolean; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footer1
    basefooter          = 1
    # cat= footer/bg1/01; type= int+; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:address
    address             = 
    # cat= footer/bg1/02; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:addressWrap
    addressWrap         = <div id= "contact" class= "col-12 col-sm-6 col-lg-3">|</div>
    # cat= footer/bg1/03; type= int+; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:service1
    service1            = 
    # cat= footer/bg1/04; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:service1Wrap
    service1Wrap            = <div class= "col-12 col-sm-6 col-lg-3">|</div>
    # cat= footer/bg1/05; type= int+; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:service2
    service2            = 
    # cat= footer/bg1/06; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:service2Wrap
    service2Wrap            = <div class= "col-12 col-sm-6 col-lg-3">|</div> 
    # cat= footer/bg1/07; type= int+; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:service3
    service3            = 
    # cat= footer/bg1/08; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:service3Wrap
    service3Wrap            = <div class= "col-12 col-sm-6 col-lg-3">|</div>    
    # cat= footer/bg1/09; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:footer1Wrap
    footer1Wrap         = <div class= "footer1"><div class= "container"><div class= "row p-0  py-sm-3 px-xxl-0 py-lg-5">|</div></div></div> 

    # cat= footer/bg2/00; type= boolean; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:base
    base                = 
    # cat= footer/bg2/01; type= string; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:copyright
    copyright           = 
    # cat= footer/bg2/02; type= boolean; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:lastchange
    lastchange          = 
    # cat= footer/bg2/03; type= boolean; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:pid
