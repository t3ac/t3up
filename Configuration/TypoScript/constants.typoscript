##############
###	PAGE###
##############

styles.content.loginform.recursive 			= 4
styles.content.loginform.redirectFirstMethod		= 1
styles.content.loginform.redirectDisable 		= 0
styles.content.loginform.redirectMode			= login,logout,getpost,userLogin,referer,refererDomains,loginError


page {
	breadcrumb{
		# customsubcategory=appearance=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:breadcrumbwrapconstants
		# cat=t3up: breadcrumbwrap//01; type=options[0,1,2]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:breadcrumbstyle
		breadcrumbstyle				= 1	
		# cat=t3up: breadcrumbwrap//02; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:breadcrumbwrap
		breadcrumbwrap				= breadcrumbrow navbar navbar-expand-lg d-none d-lg-flex p-3
		# cat=t3up: breadcrumbwrap//03; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:breadcrumbulwrap
		breadcrumbulwrap			= align-items-center list-unstyled navbar-nav me-auto	
		# cat=t3up: breadcrumbwrap//04; type=options[d-none,d-block];label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:breadcrumbstart
		breadcrumbstart				= d-block	 
		# cat=t3up: breadcrumbwrap//05; type=string;label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:breadcrumbtext
		breadcrumbtext				= Sie sind hier 		
		# cat=t3up: breadcrumbwrap//05; type=string;label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:breadcrumbtextsize
		breadcrumbtextsize			= 80% 			
	}
			
	 components {
		#	customsubcategory=appearance=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:appearance
		# cat=t3up: components/appearance/01; type=int+; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:container
		container				= 1440
		# cat=t3up: components/appearance/02; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:gutter
		gutter					= clamp(12px, 2.8vw, 24px)
		# cat=t3up: components/appearance/04; type=options[empty,access]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:access
		access					= access
		# cat=t3up: components/appearance/05; type=options[empty,meanmenu,mmenu,simplemenu]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:mobil
		mobilmenu				= mmenu					
		# cat=t3up: components/appearance/06; type=options[1,2,3,4,5,6]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bootstrapaccordion
		bootstrapaccordion		= 1	
		# cat=t3up: components/appearance/07; type=options[1,2,3,4]; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bootstraptabs
		bootstraptabs			= 1
		# cat=t3up: components/appearance/08; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:mainpadding
		mainpadding				= 0 0 $v6 0
	 }
	 
	 color {
		#	customsubcategory=base=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:basecolors
		# cat=t3up: color/base/01; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:baseColor
		baseColor				=#333333
		# cat=t3up: color/base/02; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:baseTextColor
		baseTextColor				= #333333
		# cat=t3up: color/base/03; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:baseLinkColor
		baseLinkColor				=#333333
		# cat=t3up: color/base/04; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:baseLinkHoverColor
		baseLinkHoverColor			=#000000
		# cat=t3up: color/base/05; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:bodyBgColor
		bodyBgColor				= transparent
		# cat=t3up: color/base/06; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:baseContainerBgColor
		baseContainerBgColor			=transparent
		# cat=t3up: color/base/07; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:shadow			
		shadow					=0 2px 10px 0px rgba(0,0,0,.2)

			
		#	customsubcategory=header=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:header
		# cat=t3up: color/header/01; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:headerBgColor
		headerBgColor				= inherit
		# cat=t3up: color/header/02; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:headerColor
		headerColor					= #666
		# cat=t3up: color/header/03; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:headerLinkColor
		headerLinkColor				= #666
		# cat=t3up: color/header/04; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:headerLinkHoverColor
		headerLinkHoverColor			= #333
		# cat=t3up: color/header/05; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:topBgColor
		topBgColor				= #ccc
		# cat=t3up: color/header/06; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:topBgColorTrans
		topBgColorTrans				= 1
		# cat=t3up: color/header/07; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:topLinkColor
		topLinkColor				= #666
		# cat=t3up: color/header/08; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:topLinkHoverColor
		topLinkHoverColor			= inherit
	 

		#	customsubcategory=navcolor=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:navigationcolor
		# cat=t3up: color/navcolor/01; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:navLinkColor
		navLinkColor				= #333	 
		# cat=t3up: color/navcolor/02; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:navLinkHoverColor
		navLinkHoverColor			= #000	 
		# cat=t3up: color/navcolor/03; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:subnavLinkColor
		subnavLinkColor				= #333	 
		# cat=t3up: color/navcolor/04; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:subnavLinkHoverColor
		subnavLinkHoverColor			= #000	
		# cat=t3up: color/navcolor/05; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:subNavBG
		subNavBG				= rgba(255, 255, 255, .98)	
		# cat=t3up: color/navcolor/06; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:navLinkHoverBGColor
		navLinkHoverBGColor			= rgba(255, 255, 255, 0)	
		# cat=t3up: color/navcolor/07; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:navBorderBottomColor
		navBorderBottomColor		= rgba(100, 100, 100, 1)	
		# cat=t3up: color/navcolor/08; type=string; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:overlay
		overlay					= rgba(33, 33, 33, 0.35)			 
		# cat=t3up: color/navcolor/09; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:sideankercolorBg
		sideankercolorBg			= #ffffff
		# cat=t3up: color/navcolor/10; type= color; label= LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:sideankerlicolor
		sideankerlicolor			= #333333

		#	customsubcategory=headercolor=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:headercolor
		# cat=t3up: color/headercolor/01; type=color; label=LLL:EXT:t3up/Resources/Private/Language/locallang_constants.xlf:h1-color
